<% layout("/layouts/boilerplate.ejs") %>

    <div class="container new-listing-container">

        <div class="listing-form-card">

            <h2 class="form-title">Create New Listing</h2>

            <p class="form-subtitle">
                Share your amazing place with travelers around the world.
            </p>

            <form action="/listings" method="POST">

                <div class="form-group">
                    <label>Title</label>
                    <input type="text" name="listing[title]" placeholder="Cozy Beach House" required>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea name="listing[description]" rows="3" placeholder="Tell guests about your place..."
                        required></textarea>
                </div>

                <div class="form-group">
                    <label>Image URL</label>
                    <input type="text" name="listing[image]" placeholder="https://example.com/image.jpg" required>
                </div>

                <div class="form-row">

                    <div class="form-group">
                        <label>Price</label>
                        <input type="number" name="listing[price]" placeholder="₹1500" required>
                    </div>

                    <div class="form-group">
                        <label>Location</label>
                        <input type="text" name="listing[location]" placeholder="Delhi" required>
                    </div>

                </div>

                <div class="form-group">
                    <label>Country</label>
                    <input type="text" name="listing[country]" placeholder="India" required>
                </div>

                <button class="listing-btn">
                    Publish Listing
                </button>

            </form>

        </div>

    </div>